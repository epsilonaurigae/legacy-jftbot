                /timer 28800 /mode $1 -b *!*@172.58.*
                /timer 28800 /mode $1 -b *!*@172.32.*
                /timer 28800 /mode $1 -b *!*@100.128.*
                /timer 28800 /mode $1 -b *!*@72.250.*
                /timer 28800 /mode $1 -b *!*@66.94.*

}

}

on -public "% % !shield*" {
        if ( [$ishalfop($0)] ) {
	        /say alright , I will be a little more aggressive with security for awhile.
                /exec /bin/cp /home/nnsbot/bopm/scan.on /home/nnsbot/bopm/scan.sh

}
        if ( [$ischanop($0)] ) {
	        /say alright , I will be a little more aggressive with security for awhile.
                /exec /bin/cp /home/nnsbot/bopm/scan.on /home/nnsbot/bopm/scan.sh

}

}

on -public "% % !banvzw*" {
        if ( [$ishalfop($0)] ) {
		/say Setting a 12 hour restriction on Verizon Wireless. This restriction does not apply to registered nicknames who log in with a password.
		/quote gline %*@*.myvzw.com 12h Temporary 12 hour restriction on verizon wireless due to subscriber(s) repeatedly engaging in antisocial conduct. This restriction does not apply to registered nicknames who log in with a password. Sorry for the inconvenience

}
        if ( [$ischanop($0)] ) {
                /say Setting a 12 hour restriction on Verizon Wireless. This restriction does not apply to registered nicknames who log in with a password.
                /quote gline %*@*.myvzw.com 12h Temporary 12 hour restriction on verizon wireless due to subscriber(s) repeatedly engaging in antisocial conduct. This restriction does not apply to registered nicknames who log in with a password. Sorry for the inconvenience


}

}





