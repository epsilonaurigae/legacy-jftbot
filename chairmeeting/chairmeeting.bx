                /mode $1 +b *!*@172.56.*
                /mode $1 +b *!*@172.58.*
                /mode $1 +b *!*@172.32.*
                /mode $1 +b *!*@100.128.*
                /mode $1 +b *!*@72.250.*
                /mode $1 +b *!*@66.94.*
                /timer 28800 /mode $1 -b *!*@208.54.*
