@ ::MANUALTOPIC = 0
@ ISITREADINGTIME = 1
@ ISITCLOSETIME = 1
@ ISITTIME = 1
on -public "% % !mute" {
        if ( [$ishalfop($0)] ) {
                /say "The room is now moderated. You will not be able to type into the channel unless it is your turn to share."
                /mode $1 +m

}
	if ( [$ischanop($0)] ) {
                /mode $1 +m

}

}


on -public "% % !changenick*" {
        if ( [$ishalfop($0)] ) {
                /msg operserv svsnick $3 $4 

}
        if ( [$ischanop($0)] ) {
                /msg operserv svsnick $3 $4

}

}


